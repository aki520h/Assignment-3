<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <div class="container">
        <h1>✏️ Edit Destination</h1>
        <form action="/edit/<%= item._id %>" method="POST" enctype="multipart/form-data">
            <div class="input-group">
                <input type="text" name="destination" value="<%= item.destination %>" required>
                <input type="text" name="country" value="<%= item.country %>" required>
                <input type="text" name="highlight" value="<%= item.highlight %>">
                <div style="margin-top: 15px; text-align: left;">
                    <label>Change Image (Optional):</label><br>
                    <input type="file" name="image" accept="image/*"><br>
                    <img src="<%= item.photoUrl %>" alt="current photo" width="150" style="border-radius: 10px; border: 2px solid #ddd; padding: 5px;">
                </div>
            </div>
            <button type="submit" style="margin-top: 20px;">UPDATE JOURNEY</button>
        </form>
        <div style="margin-top: 20px;">
            <a href="/add-travel" style="text-decoration: none; color: #666;">← Cancel</a>
        </div>
    </div>
</body>
</html>